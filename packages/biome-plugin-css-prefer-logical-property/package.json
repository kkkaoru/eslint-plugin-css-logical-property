  },
  "license": "MIT",
  "author": "kkkaoru",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kkkaoru/eslint-plugin-css-logical-property.git",
    "directory": "packages/biome-plugin-css-prefer-logical-property"
  },
  "files": [
    "rules"
  ],
